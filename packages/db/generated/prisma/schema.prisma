// Prisma schema for VidAI — Wedding Planner
// Scaffolded via: pnpm --filter @wedding/db exec prisma init --datasource-provider postgresql
// Prisma v7: url/directUrl moved to prisma.config.ts
// Models: wedding_intakes, recommendations, payments, finalized_budgets,
//         finalized_budget_items, actual_expenses, vendors

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model WeddingIntake {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  weddingDate    DateTime @map("wedding_date") @db.Date
  guestCount     Int      @map("guest_count")
  city           String
  venueType      String   @map("venue_type")
  budgetBracket  String   @map("budget_bracket")
  budgetMidpoint Int      @map("budget_midpoint")
  priorities     String[]
  chatHistory    Json     @default("[]") @map("chat_history")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  recommendations  Recommendation[]
  payments         Payment[]
  finalizedBudgets FinalizedBudget[]

  @@map("wedding_intakes")
}

model Recommendation {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  intakeId        String   @map("intake_id") @db.Uuid
  vendorCategory  String   @map("vendor_category")
  priorityRank    Int      @map("priority_rank")
  allocatedBudget Int      @map("allocated_budget")
  rationale       String
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  intake WeddingIntake @relation(fields: [intakeId], references: [id], onDelete: Cascade)

  @@index([intakeId], name: "idx_recommendations_intake_id")
  @@map("recommendations")
}

model Payment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  intakeId       String   @map("intake_id") @db.Uuid
  vendorCategory String   @map("vendor_category")
  vendorName     String   @map("vendor_name")
  amountPaid     Int      @map("amount_paid")
  paymentDate    DateTime @map("payment_date") @db.Date
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  intake WeddingIntake @relation(fields: [intakeId], references: [id], onDelete: Cascade)

  @@index([intakeId], name: "idx_payments_intake_id")
  @@map("payments")
}

model Vendor {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  category      String // matches vendor category slug from @wedding/types
  city          String
  description   String
  priceMin      Int      @map("price_min")
  priceMax      Int      @map("price_max")
  rating        Float    @default(4.0) // 1.0 – 5.0
  tier          String // 'budget' | 'mid' | 'premium'
  phone         String?
  email         String?
  website       String?
  coverImageUrl String?  @map("cover_image_url")
  tags          String[]
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([city, category], name: "idx_vendors_city_category")
  @@map("vendors")
}

// ─── Budget Finalization ─────────────────────────────────────────────────────

model FinalizedBudget {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  intakeId    String   @map("intake_id") @db.Uuid
  totalBudget Int      @map("total_budget")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  intake        WeddingIntake         @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  items         FinalizedBudgetItem[]
  actualExpense ActualExpense?

  @@index([intakeId], name: "idx_finalized_budgets_intake_id")
  @@map("finalized_budgets")
}

model FinalizedBudgetItem {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  budgetId       String  @map("budget_id") @db.Uuid
  vendorCategory String  @map("vendor_category")
  vendorId       String? @map("vendor_id") // null if category was dropped or AI default used
  vendorName     String? @map("vendor_name")
  finalBudget    Int     @map("final_budget") // 0 if dropped; vendor priceMin or AI allocatedBudget

  budget FinalizedBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId], name: "idx_budget_items_budget_id")
  @@map("finalized_budget_items")
}

model ActualExpense {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  budgetId String @unique @map("budget_id") @db.Uuid
  items    Json   @default("[]") // [{vendorCategory: string, actualAmount: number}]

  budget FinalizedBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@map("actual_expenses")
}
