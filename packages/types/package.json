{
  "name": "@wedding/types",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./intake": {
      "types": "./dist/intake.d.ts",
      "default": "./dist/intake.js"
    },
    "./recommendation": {
      "types": "./dist/recommendation.d.ts",
      "default": "./dist/recommendation.js"
    },
    "./payment": {
      "types": "./dist/payment.d.ts",
      "default": "./dist/payment.js"
    },
    "./budget": {
      "types": "./dist/budget.d.ts",
      "default": "./dist/budget.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "typescript": "5.9.2",
    "zod": "^3.23.8"
  }
}
